# ===========================================
# Akari Math Lab - Environment Variables
# ===========================================

# Supabase Configuration
# Get these from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin allowlist (REQUIRED for /admin and /api/admin)
# Comma-separated emails. Authenticated Supabase users NOT listed here are
# denied admin access. Unset = everyone denied (fail-closed).
ADMIN_EMAILS=you@example.com

# Revalidate Secret (for ISR webhook)
# Generate a random string for security
REVALIDATE_SECRET=your-random-secret-string

# GitHub API (optional)
# Used to raise rate limits and include private GitHub activity in aggregate counts.
GITHUB_TOKEN=github_pat_your-token

# GitHub username served by /api/github (optional; defaults to koutya0akari)
GITHUB_USERNAME=koutya0akari

# Giscus Comments (optional override)
# Defaults are configured in src/components/diary/comments.tsx.
NEXT_PUBLIC_GISCUS_REPO_ID=R_kgDOP878Hw
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_kwDOP878H84Cx8Ub
